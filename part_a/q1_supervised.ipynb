import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Assuming your file is named 'customer_data.csv' 
# (Please replace with your actual filename)
df = pd.read_csv('customer_data.csv')

# --- TASK 1: Display basic information ---
print("--- Dataset Info ---")
print(df.info())
print("\n--- Summary Statistics ---")
print(df.describe())

# --- TASK 2: Check for missing values and handle them ---
print("\n--- Missing Values Before ---")
print(df.isnull().sum())

# Logic: Drop or Fill based on column type (Course Modul 3 logic)
# Standard practice: fill numeric with mean/median, drop if critical
df = df.dropna() 
print("\n--- Missing Values After ---")
print(df.isnull().sum())

# --- TASK 3: Visualize the distribution of a numerical column ---
# Replacing 'Age' with the relevant numerical column from your dataset
plt.figure(figsize=(10, 6))
sns.histplot(df['Age'], kde=True, color='steelblue')
plt.title('Distribution of Customer Age')
plt.xlabel('Age')
plt.ylabel('Frequency')
plt.grid(True)
plt.show()
